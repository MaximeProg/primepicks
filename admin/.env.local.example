NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Firebase Auth
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=votre-projet

# Firebase Messaging (pour les push notifications web)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=   # Project Settings > General > App > Sender ID
NEXT_PUBLIC_FIREBASE_APP_ID=                # Project Settings > General > App > App ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=        # Project Settings > General > Storage Bucket
NEXT_PUBLIC_FIREBASE_VAPID_KEY=             # Project Settings > Cloud Messaging > Web push certificates > Key pair
